<Window x:Class="VoltComms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VOLT 무전기"
        Width="350" Height="250"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#FF11151A"
        Loaded="OnLoaded"
        Closing="OnWindowClosing">
    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더: 연결 상태 -->
        <DockPanel Grid.Row="0">
            <TextBlock Text="VOLT 지휘망" FontSize="14" FontWeight="Bold" Foreground="#FFE8B931"/>
            <TextBlock x:Name="ConnText" Text="● 연결 중…" FontSize="12"
                       Foreground="#FF888888" HorizontalAlignment="Right"/>
        </DockPanel>

        <TextBlock Grid.Row="1" Text="현재 발언자" FontSize="11" Foreground="#FF6E7A86" Margin="0,12,0,2"/>

        <!-- 현재 발언자 -->
        <Border Grid.Row="2" Background="#FF1A222C" CornerRadius="6" Padding="10,6" MinHeight="44">
            <TextBlock x:Name="SpeakerText" Text="—" FontSize="22" FontWeight="Bold"
                       Foreground="#FFD7E1EA" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <!-- 내 송신 상태 -->
        <TextBlock x:Name="TxText" Grid.Row="3" Text="대기 (PTT: …)" FontSize="13"
                   Foreground="#FF9AA7B4" Margin="0,10,0,0" HorizontalAlignment="Center"/>

        <!-- 계측 -->
        <TextBlock x:Name="StatsText" Grid.Row="4" Text="RTT — · 손실 —" FontSize="11"
                   Foreground="#FF5E6A76" Margin="0,8,0,0" HorizontalAlignment="Center"/>

        <!-- 접속자 명단 -->
        <TextBlock x:Name="RosterText" Grid.Row="5" Text="" FontSize="11"
                   Foreground="#FF5E6A76" Margin="0,4,0,0" HorizontalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>
    </Grid>
</Window>
