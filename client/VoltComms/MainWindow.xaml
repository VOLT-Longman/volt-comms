<Window x:Class="VoltComms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VOLT 무전기"
        Width="350" Height="450"
        MinWidth="320" MinHeight="380"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgWindow}"
        Loaded="OnLoaded"
        Closing="OnWindowClosing">
    <Grid Margin="16,12,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <DockPanel Grid.Row="0">
            <Button DockPanel.Dock="Right" Content="설정" Style="{StaticResource VoltButton}"
                    Padding="10,3" Click="OnOpenSettings"/>
            <StackPanel>
                <TextBlock Text="VOLT 지휘망" FontSize="15" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                <TextBlock x:Name="ConnText" Text="● 시작 중…" FontSize="11" Foreground="{StaticResource FgDim}" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- 현재 발언자 -->
        <Border x:Name="SpeakerPanel" Grid.Row="1" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderDim}" BorderThickness="1.5"
                CornerRadius="8" Padding="12,10" Margin="0,12,0,0" MinHeight="64">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="SpeakerCaption" Text="현재 발언자" FontSize="11"
                           Foreground="{StaticResource FgFaint}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="SpeakerText" Text="—" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource FgMain}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- 내 송신 상태 -->
        <TextBlock x:Name="TxText" Grid.Row="2" Text="대기" FontSize="13"
                   Foreground="{StaticResource FgDim}" Margin="0,10,0,0" HorizontalAlignment="Center"
                   TextWrapping="Wrap" TextAlignment="Center"/>

        <!-- 접속자 -->
        <TextBlock x:Name="RosterCaption" Grid.Row="3" Text="접속자" FontSize="11"
                   Foreground="{StaticResource FgFaint}" Margin="2,14,0,4"/>
        <Border Grid.Row="4" Background="{StaticResource BgPanel}" CornerRadius="6" Padding="10,6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="RosterList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,4">
                                <Ellipse Width="9" Height="9" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF3A4654"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                    <Setter Property="Fill" Value="#FF4CC96E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding Nick}" Foreground="{StaticResource FgMain}"
                                           FontSize="13" Margin="9,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 음량 -->
        <DockPanel Grid.Row="5" Margin="0,10,0,0">
            <TextBlock Text="음량" Style="{StaticResource FieldLabel}" FontSize="11"/>
            <TextBlock x:Name="VolumeLabel" DockPanel.Dock="Right" Width="36" TextAlignment="Right"
                       Foreground="{StaticResource FgFaint}" FontSize="11" VerticalAlignment="Center"/>
            <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" VerticalAlignment="Center"
                    ValueChanged="OnVolumeChanged"/>
        </DockPanel>

        <!-- 계측 -->
        <TextBlock x:Name="StatsText" Grid.Row="6" Text="" FontSize="10.5"
                   Foreground="{StaticResource FgFaint}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
    </Grid>
</Window>
