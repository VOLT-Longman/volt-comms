<Window x:Class="VoltComms.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VOLT 무전기 — 설정"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgWindow}"
        Loaded="OnLoaded" Closed="OnClosedWindow">
    <StackPanel Margin="20,8,20,16">

        <TextBlock Text="서버" Style="{StaticResource SectionTitle}"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/><RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="주소" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="HostBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource VoltTextBox}" Margin="0,3"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="포트" Style="{StaticResource FieldLabel}" Margin="10,0,8,0"/>
            <TextBox x:Name="PortBox" Grid.Row="0" Grid.Column="3" Style="{StaticResource VoltTextBox}" Margin="0,3"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="비밀 토큰" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TokenBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource VoltTextBox}" Margin="0,3"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="콜사인" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="NickBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource VoltTextBox}" Margin="0,3" MaxLength="16"/>
            <CheckBox x:Name="TlsCheck" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Content="TLS 사용"
                      Style="{StaticResource VoltCheckBox}" Margin="12,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Text="무전 (PTT)" Style="{StaticResource SectionTitle}"/>
        <DockPanel>
            <Button x:Name="CaptureBtn" DockPanel.Dock="Right" Content="키 변경"
                    Style="{StaticResource VoltButton}" Width="90" Click="OnCaptureClick"/>
            <Border Background="{StaticResource BgPanel}" CornerRadius="4" Padding="10,6" Margin="0,0,10,0">
                <TextBlock x:Name="PttKeyText" Foreground="{StaticResource FgMain}" FontSize="13" FontWeight="Bold"/>
            </Border>
        </DockPanel>
        <TextBlock Text="게임에서 쓰지 않는 키나 마우스 사이드 버튼을 추천합니다."
                   Foreground="{StaticResource FgFaint}" FontSize="11" Margin="2,5,0,0"/>

        <TextBlock Text="오디오" Style="{StaticResource SectionTitle}"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="마이크" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="InputCombo" Grid.Row="0" Grid.Column="1" Margin="0,3" FontSize="13"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="입력 레벨" Style="{StaticResource FieldLabel}"/>
            <ProgressBar x:Name="LevelBar" Grid.Row="1" Grid.Column="1" Height="10" Margin="0,6"
                         Minimum="0" Maximum="100" Foreground="{StaticResource Ok}" Background="{StaticResource BgControl}" BorderThickness="0"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="스피커" Style="{StaticResource FieldLabel}"/>
            <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,3">
                <Button x:Name="TestBtn" DockPanel.Dock="Right" Content="소리 테스트" Width="90" Margin="8,0,0,0"
                        Style="{StaticResource VoltButton}" Click="OnTestClick"/>
                <ComboBox x:Name="OutputCombo" FontSize="13"/>
            </DockPanel>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="수신 음량" Style="{StaticResource FieldLabel}"/>
            <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,4">
                <TextBlock x:Name="VolumeLabel" DockPanel.Dock="Right" Width="38" TextAlignment="Right"
                           Foreground="{StaticResource FgDim}" FontSize="12" VerticalAlignment="Center"/>
                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center" ValueChanged="OnVolumeChanged"/>
            </DockPanel>
        </Grid>
        <TextBlock Text="장치 변경은 저장 시 적용됩니다. 입력 레벨은 현재 사용 중인 마이크 기준입니다."
                   Foreground="{StaticResource FgFaint}" FontSize="11" Margin="2,4,0,0"/>

        <TextBlock Text="기타" Style="{StaticResource SectionTitle}"/>
        <StackPanel>
            <CheckBox x:Name="GrantBeepCheck" Content="발언권을 얻으면 확인음 재생" Style="{StaticResource VoltCheckBox}" Margin="0,2"/>
            <CheckBox x:Name="TopmostCheck" Content="창을 항상 위에 표시" Style="{StaticResource VoltCheckBox}" Margin="0,2"/>
            <CheckBox x:Name="MinimizedCheck" Content="시작 시 창을 숨기고 트레이로 실행" Style="{StaticResource VoltCheckBox}" Margin="0,2"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="{StaticResource Bad}" FontSize="12" Margin="0,10,0,0"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" Style="{StaticResource VoltButton}" Width="80" Margin="0,0,10,0" Click="OnCancelClick"/>
            <Button Content="저장" Style="{StaticResource VoltPrimaryButton}" Width="100" Click="OnSaveClick"/>
        </StackPanel>
    </StackPanel>
</Window>
