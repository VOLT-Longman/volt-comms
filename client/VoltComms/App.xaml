<Application x:Class="VoltComms.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown"
             Startup="OnAppStartup"
             Exit="OnAppExit">
    <Application.Resources>
        <!-- 브랜드 폰트: Pretendard (앱에 내장). 누락 시 시스템 폰트로 폴백. -->
        <FontFamily x:Key="AppFont">pack://application:,,,/Fonts/#Pretendard</FontFamily>

        <!-- 공용 다크 테마 팔레트 — VOLT 웹사이트 디자인 토큰과 동기화
             (순수 블랙 배경 + 오렌지 강조). 출처: volt-website css/styles.css :root -->
        <SolidColorBrush x:Key="BgWindow" Color="#FF000000"/>   <!-- color-bg-primary -->
        <SolidColorBrush x:Key="BgPanel" Color="#FF141414"/>    <!-- color-bg-card 위 카드 -->
        <SolidColorBrush x:Key="BgControl" Color="#FF1C1C1E"/>  <!-- color-bg-card-hover -->
        <SolidColorBrush x:Key="FgMain" Color="#FFF5F5F7"/>     <!-- color-text-primary -->
        <SolidColorBrush x:Key="FgDim" Color="#FFA1A1A6"/>      <!-- color-text-secondary -->
        <SolidColorBrush x:Key="FgFaint" Color="#FF86868B"/>    <!-- color-text-tertiary -->
        <SolidColorBrush x:Key="Accent" Color="#FFE8482F"/>     <!-- volt-orange -->
        <SolidColorBrush x:Key="AccentLight" Color="#FFFF5F44"/><!-- volt-orange-light -->
        <SolidColorBrush x:Key="AccentDark" Color="#FFC13A24"/> <!-- volt-orange-dark -->
        <SolidColorBrush x:Key="Ok" Color="#FF4CC96E"/>        <!-- 기능 색: 발언/접속 -->
        <SolidColorBrush x:Key="Bad" Color="#FFFF5A5A"/>       <!-- 기능 색: 오류 -->
        <SolidColorBrush x:Key="BorderDim" Color="#FF2A2A2C"/>  <!-- color-border -->

        <Style x:Key="VoltButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
            <Setter Property="Background" Value="{StaticResource BgControl}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2A2A2C"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3D3D40"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF0E0E0E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource FgFaint}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 오렌지 채움 강조 버튼. 자체 템플릿으로 hover 시 오렌지를 유지한다. -->
        <Style x:Key="VoltPrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentDark}"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgControl}"/>
                                <Setter Property="Foreground" Value="{StaticResource FgFaint}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VoltTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgControl}"/>
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="CaretBrush" Value="{StaticResource FgMain}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="VoltCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgDim}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>
    </Application.Resources>
</Application>
